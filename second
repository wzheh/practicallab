import 'dart:math';

import 'package:device_preview/device_preview.dart';
import 'package:flutter/foundation.dart';
import 'package:flutter/material.dart';

void main() {
  runApp(
    DevicePreview(
      enabled: !kReleaseMode,
      builder: (context) => const ShapeLabApp(),
    ),
  );
}

class ShapeLabApp extends StatelessWidget {
  const ShapeLabApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      locale: DevicePreview.locale(context),
      builder: DevicePreview.appBuilder,
      home: const ShapeLabPage(),
    );
  }
}

class ShapeLabPage extends StatefulWidget {
  const ShapeLabPage({super.key});

  @override
  State<ShapeLabPage> createState() => _ShapeLabPageState();
}

class _ShapeLabPageState extends State<ShapeLabPage> {
  final Random random = Random();

  Color buttonColor = const Color(0xFFBF360C);
  String buttonText = 'Change Burger';

  final List<Color> buttonColors = const [
    Color(0xFFE64A19),
    Color(0xFF7B1FA2),
    Color(0xFF00796B),
    Color(0xFFFBC02D),
  ];

  final List<String> buttonTexts = const [
    'Yummy!',
    'Burger Ready',
    'Lunch Mode',
    'Extra Cheese',
  ];

  void changeButton() {
    setState(() {
      buttonColor = buttonColors[random.nextInt(buttonColors.length)];
      buttonText = buttonTexts[random.nextInt(buttonTexts.length)];
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Burger Icon Lab'),
        backgroundColor: const Color(0xFF0D47A1),
        centerTitle: true,
      ),
      body: Padding(
        padding: const EdgeInsets.all(30),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            SizedBox(
              width: 320,
              height: 360,
              child: Stack(
                children: [
                  Container(
                    width: 320,
                    height: 360,
                    decoration: BoxDecoration(
                      color: const Color(0xFFFFF8E1),
                      border: Border.all(
                        color: const Color(0xFFFFB300),
                        width: 3,
                      ),
                      borderRadius: BorderRadius.circular(18),
                    ),
                  ),
                  Positioned(
                    left: 95,
                    top: 120,
                    child: Container(
                      width: 130,
                      height: 50,
                      decoration: BoxDecoration(
                        color: const Color(0xFFFFCA28),
                        borderRadius: BorderRadius.circular(25),
                      ),
                    ),
                  ),
                  Positioned(
                    left: 85,
                    top: 178,
                    child: Container(
                      width: 150,
                      height: 35,
                      decoration: BoxDecoration(
                        color: const Color(0xFF6D4C41),
                        borderRadius: BorderRadius.circular(8),
                      ),
                    ),
                  ),
                  Positioned(
                    left: 130,
                    top: 225,
                    child: Container(
                      width: 60,
                      height: 60,
                      decoration: const BoxDecoration(
                        color: Color(0xFFE53935),
                        shape: BoxShape.circle,
                      ),
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 20),
            SizedBox(
              width: 230,
              height: 48,
              child: ElevatedButton(
                onPressed: changeButton,
                style: ElevatedButton.styleFrom(
                  backgroundColor: buttonColor,
                  foregroundColor: Colors.white,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(14),
                  ),
                ),
                child: Text(buttonText),
              ),
            ),
          ],
        ),
      ),
    );
  }
}